# clang-tidy 配置示例
# 对应文章：《还在996？……》第二招"静态分析"
# 用法： clang-tidy your_file.c -- -I.
---
Checks: >
  clang-analyzer-*,
  bugprone-*,
  cert-*,
  misc-*,
  performance-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length
WarningsAsErrors: 'clang-analyzer-*,bugprone-*'
HeaderFilterRegex: '.*'
